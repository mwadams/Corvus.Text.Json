@model SiteViewModel
@{
    Layout = "../Shared/_Layout.cshtml";
}
<div class="layout-docs container">
    <aside class="sidebar">
        <div class="sidebar__section">
            <button class="sidebar__heading">Namespaces</button>
            <div class="sidebar__body">
                <ul class="sidebar__list">
                    <li class="sidebar__item"><a class="sidebar__link" href="/api/corvus-text-json.html">Corvus.Text.Json</a></li>
                    <li class="sidebar__item"><a class="sidebar__link" href="/api/corvus-text-json-internal.html">Corvus.Text.Json.Internal</a></li>
                    <li class="sidebar__item"><a class="sidebar__link" href="/api/corvus-numerics.html">Corvus.Numerics</a></li>
                    <li class="sidebar__item"><a class="sidebar__link" href="/api/corvus-text-json-compatibility.html">Corvus.Text.Json.Compatibility</a></li>
                    <li class="sidebar__item"><a class="sidebar__link" href="/api/corvus-globalization.html">Corvus.Globalization</a></li>
                    <li class="sidebar__item"><a class="sidebar__link" href="/api/corvus-runtime-interopservices.html">Corvus.Runtime.InteropServices</a></li>
                </ul>
            </div>
        </div>
    </aside>
    <main id="main-content" class="layout-docs__main">
        <div class="doc__content">
            <h1>@Model.PageContext.Title</h1>
            @foreach (var contentFragment in Model.PageContext.GetAllMarkdownContent())
            {
                @Html.Raw(contentFragment.Body)
            }
        </div>
    </main>
</div>
