@model SiteViewModel
@{
    Layout = "../Shared/_Layout.cshtml";
}
<section class="hero hero--compact">
    <div class="hero__content">
        <h1 class="hero__title">Example Recipes</h1>
        <p class="hero__subtitle">Runnable examples demonstrating JSON Schema patterns with the V5 code generator</p>
    </div>
</section>
<div class="container section">
    <div class="card-grid">
        <a class="card card--link" href="/examples/data-object.html">
            <span class="card__tag">001</span>
            <h3 class="card__title">Data Object</h3>
            <p class="card__body">Parsing, property access, string comparison, serialization, equality</p>
        </a>
        <a class="card card--link" href="/examples/data-object-validation.html">
            <span class="card__tag">002</span>
            <h3 class="card__title">Data Object Validation</h3>
            <p class="card__body">Schema constraints, EvaluateSchema(), detailed validation results</p>
        </a>
        <a class="card card--link" href="/examples/reusing-common-types.html">
            <span class="card__tag">003</span>
            <h3 class="card__title">Reusing Common Types</h3>
            <p class="card__body">$ref / $defs, shared nested types</p>
        </a>
        <a class="card card--link" href="/examples/open-versus-closed-types.html">
            <span class="card__tag">004</span>
            <h3 class="card__title">Open vs Closed Types</h3>
            <p class="card__body">additionalProperties, mutable RemoveProperty / SetProperty</p>
        </a>
        <a class="card card--link" href="/examples/extending-a-base-type.html">
            <span class="card__tag">005</span>
            <h3 class="card__title">Extending a Base Type</h3>
            <p class="card__body">Schema inheritance via $ref, From() conversion</p>
        </a>
        <a class="card card--link" href="/examples/constraining-a-base-type.html">
            <span class="card__tag">006</span>
            <h3 class="card__title">Constraining a Base Type</h3>
            <p class="card__body">Tighter constraints on a base, validation differences</p>
        </a>
        <a class="card card--link" href="/examples/strongly-typed-array.html">
            <span class="card__tag">007</span>
            <h3 class="card__title">Strongly Typed Array</h3>
            <p class="card__body">Array mutation via builder, indexing, enumeration</p>
        </a>
        <a class="card card--link" href="/examples/higher-rank-array.html">
            <span class="card__tag">008</span>
            <h3 class="card__title">Higher Rank Array</h3>
            <p class="card__body">2D arrays, multi-index access</p>
        </a>
        <a class="card card--link" href="/examples/working-with-tensors.html">
            <span class="card__tag">009</span>
            <h3 class="card__title">Working with Tensors</h3>
            <p class="card__body">3D tensors, TryGetNumericValues, Build, CreateBuilder, Rank, Dimension</p>
        </a>
        <a class="card card--link" href="/examples/creating-tuples.html">
            <span class="card__tag">010</span>
            <h3 class="card__title">Creating Tuples</h3>
            <p class="card__body">CreateTuple via builder, Item1/Item2/Item3 access</p>
        </a>
        <a class="card card--link" href="/examples/interfaces-and-mixins.html">
            <span class="card__tag">011</span>
            <h3 class="card__title">Interfaces and Mix-Ins</h3>
            <p class="card__body">allOf composition, From() conversion</p>
        </a>
        <a class="card card--link" href="/examples/pattern-matching.html">
            <span class="card__tag">012</span>
            <h3 class="card__title">Pattern Matching</h3>
            <p class="card__body">oneOf, Match with named parameters</p>
        </a>
        <a class="card card--link" href="/examples/polymorphism-with-discriminators.html">
            <span class="card__tag">013</span>
            <h3 class="card__title">Polymorphism with Discriminators</h3>
            <p class="card__body">const discriminator properties, Match</p>
        </a>
        <a class="card card--link" href="/examples/string-enumerations.html">
            <span class="card__tag">014</span>
            <h3 class="card__title">String Enumerations</h3>
            <p class="card__body">String enum, Match with state</p>
        </a>
        <a class="card card--link" href="/examples/numeric-enumerations.html">
            <span class="card__tag">015</span>
            <h3 class="card__title">Numeric Enumerations</h3>
            <p class="card__body">Numeric const, ConstInstance, explicit conversion</p>
        </a>
        <a class="card card--link" href="/examples/maps.html">
            <span class="card__tag">016</span>
            <h3 class="card__title">Maps</h3>
            <p class="card__body">Typed map (object with additionalProperties), builder construction</p>
        </a>
        <a class="card card--link" href="/examples/mapping-input-output.html">
            <span class="card__tag">017</span>
            <h3 class="card__title">Mapping Input/Output</h3>
            <p class="card__body">Cross-model mapping, From(), mutable pipeline</p>
        </a>
    </div>
</div>
