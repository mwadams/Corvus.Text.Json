@model SiteViewModel
@{
    Layout = "../Shared/_Layout.cshtml";
}
<section class="hero hero--compact">
    <div class="hero__content">
        <h1 class="hero__title">Documentation</h1>
        <p class="hero__subtitle">In-depth guides for core types and migration</p>
    </div>
</section>
<div class="container section">
    <div class="card-grid">
        <a class="card card--link" href="/docs/parsed-json-document.html">
            <h3 class="card__title">ParsedJsonDocument</h3>
            <p class="card__body">Pooled-memory document parsing with ArrayPool&lt;byte&gt;. The primary way to parse and access JSON data.</p>
        </a>
        <a class="card card--link" href="/docs/json-document-builder.html">
            <h3 class="card__title">JsonDocumentBuilder</h3>
            <p class="card__body">Mutable JSON documents with workspace-managed pooled memory for building and modifying JSON.</p>
        </a>
        <a class="card card--link" href="/docs/migrating-from-v4.html">
            <h3 class="card__title">Migrating from V4 to V5</h3>
            <p class="card__body">Step-by-step migration guide covering namespace changes, API differences, and new features.</p>
        </a>
    </div>
</div>
