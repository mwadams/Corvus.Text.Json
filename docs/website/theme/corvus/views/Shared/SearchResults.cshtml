<!-- Search results overlay -->
<div class="search-overlay js-search-results-wrapper" hidden>
    <div class="search-overlay__backdrop js-search-overlay-close"></div>
    <div class="search-overlay__panel">
        <div class="search-overlay__header">
            <h2 class="search-overlay__title">Search Results</h2>
            <button class="search-overlay__close btn-plain js-search-overlay-close" aria-label="Close search results">
                <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                    <line x1="18" y1="6" x2="6" y2="18"></line>
                    <line x1="6" y1="6" x2="18" y2="18"></line>
                </svg>
            </button>
        </div>
        <div class="search-overlay__body">
            <!-- Results list populated by JS -->
            <div id="search-list" class="search-results"></div>
            <!-- No results message -->
            <div id="search-no-results" class="search-results__empty" hidden>
                <p>No results found. Try a different search term.</p>
            </div>
        </div>
        <!-- Attribution -->
        <div id="search-attribution" class="search-overlay__attribution"></div>
    </div>
</div>
<!-- /Search results overlay -->
