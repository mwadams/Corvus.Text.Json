{
    "$schema": "https://json-schema.org/draft/2020-12/schema",
    "$id": "https://example.com/person.schema.json",
    "title": "Person",
    "description": "A person entity with contact information",
    "type": "object",
    "required": ["name", "age"],
    "properties": {
        "name": {
            "type": "string",
            "description": "The person's full name",
            "minLength": 1,
            "maxLength": 100
        },
        "age": {
            "type": "number",
            "description": "The person's age in years",
            "format": "int32",
            "minimum": 0,
            "maximum": 130
        },
        "email": {
            "type": "string",
            "description": "The person's email address",
            "format": "email"
        },
        "phoneNumber": {
            "type": "string",
            "description": "The person's phone number",
            "pattern": "^\\+?[1-9]\\d{1,14}$"
        },
        "address": {
            "$ref": "#/$defs/Address",
            "description": "The person's home address"
        },
        "hobbies": {
            "type": "array",
            "description": "List of the person's hobbies",
            "items": {
                "type": "string"
            }
        },
        "isActive": {
            "type": "boolean",
            "description": "Whether the person's account is active",
            "default": true
        }
    },
    "$defs": {
        "Address": {
            "type": "object",
            "description": "A physical address",
            "required": ["street", "city", "country"],
            "properties": {
                "street": {
                    "type": "string",
                    "description": "Street address"
                },
                "city": {
                    "type": "string",
                    "description": "City name"
                },
                "state": {
                    "type": "string",
                    "description": "State or province"
                },
                "zipCode": {
                    "type": "string",
                    "description": "Postal/ZIP code",
                    "pattern": "^[0-9]{5}(?:-[0-9]{4})?$"
                },
                "country": {
                    "type": "string",
                    "description": "Country name"
                }
            }
        }
    }
}
