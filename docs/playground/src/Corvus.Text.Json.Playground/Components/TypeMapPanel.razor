@namespace Corvus.Text.Json.Playground.Components

<div class="type-map-tree">
    @if (TypeMap.Count == 0)
    {
        <p style="color:#808080;padding:16px;">Click <strong>Generate</strong> to create types from the schema.</p>
    }
    else
    {
        <ul>
            @foreach (var entry in TypeMap)
            {
                <li>
                    <div class="type-map-entry @GetEntryClass(entry)"
                         @onclick="() => SelectType(entry)">
                        <span class="type-name">@entry.TypeName</span>
                        <span class="type-kind">(@entry.Kind)</span>
                    </div>
                    @if (entry.Properties.Count > 0)
                    {
                        <ul>
                            @foreach (var prop in entry.Properties)
                            {
                                <li>
                                    <div class="type-map-entry @GetPropertyClass(prop)"
                                         @onclick="() => SelectProperty(prop)">
                                        <span class="prop-name">@prop.DotnetPropertyName</span>
                                        <span class="prop-type">: @prop.TypeName</span>
                                        @if (prop.IsRequired)
                                        {
                                            <span class="prop-required">required</span>
                                        }
                                    </div>
                                </li>
                            }
                        </ul>
                    }
                </li>
            }
        </ul>
    }
</div>

@code {
    [Parameter]
    public IReadOnlyList<TypeMapEntry> TypeMap { get; set; } = [];

    [Parameter]
    public EventCallback<SchemaNavigation> OnSchemaPointerSelected { get; set; }

    private string? selectedItemKey;
    private string? relatedFullTypeName;

    private async Task SelectType(TypeMapEntry entry)
    {
        selectedItemKey = $"type:{entry.FullTypeName}";
        relatedFullTypeName = null;
        await OnSchemaPointerSelected.InvokeAsync(
            new SchemaNavigation(entry.SchemaPointer, entry.SourceSchemaName));
    }

    private async Task SelectProperty(TypeMapProperty prop)
    {
        selectedItemKey = $"prop:{prop.Name}:{prop.FullTypeName}";
        relatedFullTypeName = prop.FullTypeName;
        await OnSchemaPointerSelected.InvokeAsync(
            new SchemaNavigation(prop.SchemaPointer, prop.SourceSchemaName));
    }

    private string GetEntryClass(TypeMapEntry entry)
    {
        if (selectedItemKey == $"type:{entry.FullTypeName}")
        {
            return "selected";
        }

        if (relatedFullTypeName is not null && entry.FullTypeName == relatedFullTypeName)
        {
            return "related";
        }

        return "";
    }

    private string GetPropertyClass(TypeMapProperty prop)
    {
        if (selectedItemKey == $"prop:{prop.Name}:{prop.FullTypeName}")
        {
            return "selected";
        }

        return "";
    }

    public record SchemaNavigation(string? Pointer, string? SchemaName);
}
