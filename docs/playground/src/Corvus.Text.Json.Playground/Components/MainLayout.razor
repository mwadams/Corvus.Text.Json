@inherits LayoutComponentBase
@page "/"
@inject CodeGenerationService CodeGenService
@inject CompilationService CompilationSvc
@inject ExecutionService ExecutionSvc
@inject IntelliSenseService IntelliSenseSvc
@inject IJSRuntime JSRuntime

<div class="playground-toolbar">
    <h1>Corvus.Text.Json Playground</h1>
    <select class="toolbar-select" @onchange="OnSampleChanged">
        <option value="">— Select a sample —</option>
        <option value="SimpleObject" selected>Person (simple object)</option>
    </select>
    <div class="spacer"></div>
    <button class="toolbar-btn primary" @onclick="GenerateAsync" disabled="@isGenerating">
        @(isGenerating ? "Generating…" : "Generate")
    </button>
    <button class="toolbar-btn primary" @onclick="RunAsync" disabled="@(generationResult is null || isRunning)">
        @(isRunning ? "Running…" : "Run")
    </button>
</div>

<div class="playground-grid @(maximizedPanel is not null ? "has-maximized" : "")">
    @* Top-left: Schema editor *@
    <div class="playground-panel @(GetPanelClass("schema"))">
        <div class="panel-header">
            JSON Schema
            <div class="spacer"></div>
            <button class="panel-maximize-btn" @onclick='() => ToggleMaximize("schema")' title="@(maximizedPanel == "schema" ? "Restore" : "Maximize")">
                @(maximizedPanel == "schema" ? "⊟" : "⊞")
            </button>
        </div>
        <div class="panel-content">
            <StandaloneCodeEditor @ref="schemaEditor"
                Id="schema-editor"
                ConstructionOptions="SchemaEditorOptions"
                OnDidInit="OnSchemaEditorInit" />
        </div>
    </div>

    @* Top-right: Type map *@
    <div class="playground-panel @(GetPanelClass("typemap"))">
        <div class="panel-header">
            Type Map
            @if (generationResult?.TypeMap.Count > 0)
            {
                <span class="badge">@generationResult.TypeMap.Count types</span>
            }
        </div>
        <div class="panel-content">
            <TypeMapPanel TypeMap="@(generationResult?.TypeMap ?? [])"
                          OnSchemaPointerSelected="OnSchemaPointerSelected" />
        </div>
    </div>

    @* Bottom-left: User code editor *@
    <div class="playground-panel @(GetPanelClass("usercode"))">
        <div class="panel-header">
            User Code (C#)
            <div class="spacer"></div>
            <button class="panel-copy-btn" @onclick="CopyUserCode" title="Copy code">📋</button>
            <button class="panel-maximize-btn" @onclick='() => ToggleMaximize("usercode")' title="@(maximizedPanel == "usercode" ? "Restore" : "Maximize")">
                @(maximizedPanel == "usercode" ? "⊟" : "⊞")
            </button>
        </div>
        <div class="panel-content">
            <StandaloneCodeEditor @ref="userCodeEditor"
                Id="user-code-editor"
                ConstructionOptions="UserCodeEditorOptions"
                OnDidInit="OnUserCodeEditorInit" />
        </div>
    </div>

    @* Bottom-right: Console output *@
    <div class="playground-panel @(GetPanelClass("console"))">
        <div class="panel-header">
            Console Output
            <div class="spacer"></div>
            <button class="panel-copy-btn" @onclick="CopyConsoleOutput" title="Copy output">📋</button>
            <button class="panel-maximize-btn" @onclick='() => ToggleMaximize("console")' title="@(maximizedPanel == "console" ? "Restore" : "Maximize")">
                @(maximizedPanel == "console" ? "⊟" : "⊞")
            </button>
        </div>
        <div class="panel-content">
            <div class="console-output" @ref="consoleDiv">
                @foreach (var line in consoleLines)
                {
                    <span class="@line.CssClass">@line.Text</span>
                }
            </div>
        </div>
    </div>
</div>

<div class="status-bar @(statusError ? "error" : "")">
    <span class="status-item">@statusText</span>
</div>

@code {
    private StandaloneCodeEditor? schemaEditor;
    private StandaloneCodeEditor? userCodeEditor;
    private ElementReference consoleDiv;
    private GenerationResult? generationResult;
    private bool isGenerating;
    private bool isRunning;
    private string statusText = "Ready";
    private bool statusError;
    private List<ConsoleLine> consoleLines = [];
    private string? maximizedPanel;

    private string defaultSchema = "";

    private StandaloneEditorConstructionOptions SchemaEditorOptions(StandaloneCodeEditor editor)
    {
        return new StandaloneEditorConstructionOptions
        {
            AutomaticLayout = true,
            Language = "json",
            Theme = "vs-dark",
            Value = defaultSchema,
            FontSize = 13,
            Minimap = new EditorMinimapOptions { Enabled = false },
            ScrollBeyondLastLine = false,
        };
    }

    private StandaloneEditorConstructionOptions UserCodeEditorOptions(StandaloneCodeEditor editor)
    {
        return new StandaloneEditorConstructionOptions
        {
            AutomaticLayout = true,
            Language = "csharp",
            Theme = "vs-dark",
            Value = "// Generate types first, then write code here\n",
            FontSize = 13,
            Minimap = new EditorMinimapOptions { Enabled = false },
            ScrollBeyondLastLine = false,
        };
    }

    protected override async Task OnInitializedAsync()
    {
        // Load the default sample schema
        defaultSchema = LoadEmbeddedSample("SimpleObject");
    }

    private async Task OnSchemaEditorInit()
    {
        // Editor is ready
    }

    private DotNetObjectReference<MainLayout>? intelliSenseRef;

    private async Task OnUserCodeEditorInit()
    {
        await RegisterCompletionProvider();
    }

    private async Task RegisterCompletionProvider()
    {
        this.intelliSenseRef = DotNetObjectReference.Create(this);
        await JSRuntime.InvokeVoidAsync("registerCSharpCompletionProvider", this.intelliSenseRef);
    }

    [JSInvokable]
    public async Task<List<object>> GetCompletionsForJs(string code, int line, int column)
    {
        var items = await IntelliSenseSvc.GetCompletionsAsync(code, line, column);

        return items.Select(item => (object)new
        {
            label = item.Label,
            kind = MapMonacoKind(item.Kind),
            detail = item.Detail,
            insertText = item.Label,
            sortText = item.SortText,
            filterText = item.FilterText,
        }).ToList();
    }

    private static int MapMonacoKind(string kind)
    {
        // Monaco CompletionItemKind integer values
        return kind switch
        {
            "Method" => 0,
            "Function" => 1,
            "Field" => 3,
            "Variable" => 4,
            "Class" => 5,
            "Struct" => 6,
            "Interface" => 7,
            "Module" => 8,
            "Property" => 9,
            "Event" => 10,
            "Constant" => 14,
            "Enum" => 15,
            "EnumMember" => 16,
            "Keyword" => 17,
            "Snippet" => 27,
            "TypeParameter" => 24,
            _ => 18, // Text
        };
    }

    private async Task CopyUserCode()
    {
        if (userCodeEditor is not null)
        {
            string code = await userCodeEditor.GetValue();
            await JSRuntime.InvokeVoidAsync("navigator.clipboard.writeText", code);
        }
    }

    private async Task CopyConsoleOutput()
    {
        string text = string.Join("\n", consoleLines.Select(l => l.Text));
        await JSRuntime.InvokeVoidAsync("navigator.clipboard.writeText", text);
    }

    private async Task OnSampleChanged(ChangeEventArgs e)
    {
        string? sampleName = e.Value?.ToString();
        if (!string.IsNullOrEmpty(sampleName) && schemaEditor is not null)
        {
            string content = LoadEmbeddedSample(sampleName);
            await schemaEditor.SetValue(content);
        }
    }

    private async Task GenerateAsync()
    {
        if (schemaEditor is null)
        {
            return;
        }

        isGenerating = true;
        statusText = "Generating types…";
        statusError = false;
        StateHasChanged();

        try
        {
            string schemaJson = await schemaEditor.GetValue();
            generationResult = await CodeGenService.GenerateAsync(schemaJson);

            if (generationResult.Success)
            {
                statusText = $"Generated {generationResult.TypeMap.Count} types, {generationResult.GeneratedFiles.Count} files";

                // Update IntelliSense with the generated code
                IntelliSenseSvc.UpdateGeneratedCode(generationResult.GeneratedFiles);

                // Emit default user code if editor is empty or has only the placeholder
                if (userCodeEditor is not null)
                {
                    string currentCode = await userCodeEditor.GetValue();
                    if (string.IsNullOrWhiteSpace(currentCode) ||
                        currentCode.StartsWith("// Generate types first"))
                    {
                        string defaultCode = DefaultCodeEmitter.Emit(generationResult.TypeMap);
                        await userCodeEditor.SetValue(defaultCode);
                    }
                }
            }
            else
            {
                statusText = generationResult.ErrorMessage ?? "Generation failed";
                statusError = true;
                WriteConsole(generationResult.ErrorMessage ?? "Generation failed", "error");
            }
        }
        catch (Exception ex)
        {
            statusText = $"Error: {ex.Message}";
            statusError = true;
            WriteConsole($"Error: {ex.Message}", "error");
        }
        finally
        {
            isGenerating = false;
            StateHasChanged();
        }
    }

    private CancellationTokenSource? runCts;

    private async Task RunAsync()
    {
        if (generationResult is null || !generationResult.Success || userCodeEditor is null)
        {
            return;
        }

        isRunning = true;
        consoleLines.Clear();
        statusText = "Loading assemblies…";
        statusError = false;
        StateHasChanged();

        try
        {
            runCts?.Cancel();
            runCts = new CancellationTokenSource();

            // Clear previous error markers
            await ClearEditorMarkers();

            string userCode = await userCodeEditor.GetValue();

            // Step 1: Compile generated code + user code
            statusText = "Building…";
            StateHasChanged();

            // Allow UI to update before blocking compilation
            await Task.Delay(50);

            CompilationResult compilationResult = await CompilationSvc.CompileAsync(
                generationResult.GeneratedFiles,
                userCode);

            if (!compilationResult.Success)
            {
                statusText = $"Build failed — {compilationResult.Diagnostics.Count} error(s)";
                statusError = true;

                await SetEditorMarkers(compilationResult.Diagnostics);

                foreach (var diagnostic in compilationResult.Diagnostics)
                {
                    string location = diagnostic.Location.IsInSource
                        ? $" (line {diagnostic.Location.GetLineSpan().StartLinePosition.Line + 1})"
                        : string.Empty;
                    WriteConsole($"{diagnostic.Severity}: {diagnostic.GetMessage()}{location}", "error");
                }

                return;
            }

            if (compilationResult.Assembly is null)
            {
                statusText = "Build produced no output";
                statusError = true;
                return;
            }

            // Step 2: Execute the compiled assembly
            statusText = "Running…";
            StateHasChanged();

            ExecutionResult executionResult = await ExecutionSvc.ExecuteAsync(
                compilationResult.Assembly,
                runCts.Token);

            if (!string.IsNullOrEmpty(executionResult.Output))
            {
                foreach (string line in executionResult.Output.Split('\n'))
                {
                    if (!string.IsNullOrEmpty(line))
                    {
                        WriteConsole(line.TrimEnd('\r'));
                    }
                }
            }

            if (executionResult.Success)
            {
                statusText = "Execution complete";
            }
            else
            {
                statusText = "Execution failed";
                statusError = true;
                if (executionResult.ErrorMessage is not null)
                {
                    WriteConsole(executionResult.ErrorMessage, "error");
                }
            }
        }
        catch (Exception ex)
        {
            statusText = $"Error: {ex.Message}";
            statusError = true;
            WriteConsole($"Error: {ex.Message}", "error");
        }
        finally
        {
            isRunning = false;
            StateHasChanged();
        }
    }

    private async Task SetEditorMarkers(List<Microsoft.CodeAnalysis.Diagnostic> diagnostics)
    {
        if (userCodeEditor is null)
        {
            return;
        }

        var model = await userCodeEditor.GetModel();
        if (model is null)
        {
            return;
        }

        var markers = new List<MarkerData>();
        foreach (var diagnostic in diagnostics)
        {
            // Only show markers for user code (Program.cs), not generated files
            if (!diagnostic.Location.IsInSource)
            {
                continue;
            }

            var lineSpan = diagnostic.Location.GetLineSpan();
            if (lineSpan.Path != "Program.cs")
            {
                continue;
            }

            var start = lineSpan.StartLinePosition;
            var end = lineSpan.EndLinePosition;

            markers.Add(new MarkerData
            {
                Message = diagnostic.GetMessage(),
                Severity = diagnostic.Severity == Microsoft.CodeAnalysis.DiagnosticSeverity.Error
                    ? MarkerSeverity.Error
                    : MarkerSeverity.Warning,
                StartLineNumber = start.Line + 1,
                StartColumn = start.Character + 1,
                EndLineNumber = end.Line + 1,
                EndColumn = end.Character + 1,
            });
        }

        await BlazorMonaco.Editor.Global.SetModelMarkers(JSRuntime, model, "playground", markers);
    }

    private async Task ClearEditorMarkers()
    {
        if (userCodeEditor is null)
        {
            return;
        }

        var model = await userCodeEditor.GetModel();
        if (model is not null)
        {
            await BlazorMonaco.Editor.Global.SetModelMarkers(JSRuntime, model, "playground", []);
        }
    }

    private async Task OnSchemaPointerSelected(string? pointer)
    {
        if (schemaEditor is null || pointer is null)
        {
            return;
        }

        // Find the line in the schema editor that corresponds to this JSON pointer
        string schemaText = await schemaEditor.GetValue();
        int line = FindLineForJsonPointer(schemaText, pointer);
        if (line > 0)
        {
            await schemaEditor.RevealLineInCenter(line);
            await schemaEditor.SetPosition(new Position { LineNumber = line, Column = 1 }, "");
        }
    }

    /// <summary>
    /// Finds the 1-based line number in a JSON string that corresponds to a JSON pointer.
    /// E.g. "#/properties/address" finds the line containing "address" under "properties".
    /// </summary>
    private static int FindLineForJsonPointer(string json, string pointer)
    {
        // Strip leading "#" or "#/"
        string path = pointer.TrimStart('#').TrimStart('/');
        if (string.IsNullOrEmpty(path))
        {
            return 1;
        }

        string[] segments = path.Split('/');
        string[] lines = json.Split('\n');

        // Walk through segments, finding each key in order
        int currentLine = 0;
        foreach (string segment in segments)
        {
            // Unescape JSON Pointer encoding
            string key = segment.Replace("~1", "/").Replace("~0", "~");
            string searchPattern = $"\"{key}\"";

            bool found = false;
            for (int i = currentLine; i < lines.Length; i++)
            {
                if (lines[i].Contains(searchPattern))
                {
                    currentLine = i;
                    found = true;
                    break;
                }
            }

            if (!found)
            {
                return currentLine + 1; // Return best match so far (1-based)
            }
        }

        return currentLine + 1; // Convert to 1-based
    }

    private void WriteConsole(string text, string cssClass = "")
    {
        consoleLines.Add(new ConsoleLine(text + "\n", cssClass));
    }

    private static string LoadEmbeddedSample(string name)
    {
        var assembly = typeof(MainLayout).Assembly;
        using var stream = assembly.GetManifestResourceStream($"Sample.{name}");
        if (stream is null)
        {
            return $"// Sample '{name}' not found";
        }

        using var reader = new StreamReader(stream);
        return reader.ReadToEnd();
    }

    private void ToggleMaximize(string panelName)
    {
        maximizedPanel = maximizedPanel == panelName ? null : panelName;
    }

    private string GetPanelClass(string panelName)
    {
        if (maximizedPanel is null)
        {
            return "";
        }

        return maximizedPanel == panelName ? "maximized" : "hidden";
    }

    private record ConsoleLine(string Text, string CssClass);
}
