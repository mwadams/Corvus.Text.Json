@inherits LayoutComponentBase
@page "/"
@inject CodeGenerationService CodeGenService
@inject CompilationService CompilationSvc
@inject ExecutionService ExecutionSvc
@inject IntelliSenseService IntelliSenseSvc
@inject IJSRuntime JSRuntime

<div class="playground-toolbar">
    <h1>Corvus.Text.Json Playground</h1>
    <select class="toolbar-select" @onchange="OnSampleChanged">
        <option value="new" selected="@(activeSampleId == "new")">New Project</option>
        @foreach (var sample in availableSamples)
        {
            <option value="@sample.Id" selected="@(sample.Id == activeSampleId)">@sample.DisplayName</option>
        }
    </select>
    <div class="spacer"></div>
    <button class="toolbar-btn primary" @onclick="GenerateAsync" disabled="@isGenerating">
        @(isGenerating ? "Generating…" : "Generate")
    </button>
    <button class="toolbar-btn primary" @onclick="RunAsync" disabled="@(generationResult is null || isRunning)">
        @(isRunning ? "Running…" : "Run")
    </button>
</div>

<div class="playground-grid @(maximizedPanel is not null ? "has-maximized" : "")">
    @* Top-left: Schema editor with tabs *@
    <div class="playground-panel @(GetPanelClass("schema"))">
        <div class="panel-header">
            JSON Schema
            <div class="spacer"></div>
            <button class="panel-maximize-btn" @onclick='() => ToggleMaximize("schema")' title="@(maximizedPanel == "schema" ? "Restore" : "Maximize")">
                @(maximizedPanel == "schema" ? "⊟" : "⊞")
            </button>
        </div>
        <div class="schema-tabs">
            @for (int i = 0; i < schemaFiles.Count; i++)
            {
                int index = i;
                var file = schemaFiles[index];
                <div class="schema-tab @(index == activeSchemaIndex ? "active" : "") @(file.IsRootType ? "root-type" : "")"
                     @onclick="() => SelectSchemaTab(index)">
                    @if (renamingTabIndex == index)
                    {
                        <input @ref="renameInputRef"
                               class="schema-tab-rename-input"
                               @bind="renameValue"
                               @bind:event="oninput"
                               @onclick:stopPropagation="true"
                               @onkeydown="OnRenameKeyDown"
                               @onblur="CommitRename" />
                    }
                    else
                    {
                        <span class="schema-tab-name">@file.Name</span>
                        <button class="schema-tab-rename-btn"
                                @onclick:stopPropagation="true"
                                @onclick="() => StartRename(index)"
                                title="Rename">✎</button>
                    }
                    <button class="schema-tab-root-badge @(file.IsRootType ? "is-root" : "")"
                            @onclick:stopPropagation="true"
                            @onclick="() => ToggleRootType(index)"
                            title="@(file.IsRootType ? "This schema will be generated (click to unmark)" : "Click to generate types from this schema")">
                        @(file.IsRootType ? "GENERATE" : "REFERENCE")
                    </button>
                    @if (schemaFiles.Count > 1)
                    {
                        <button class="schema-tab-close"
                                @onclick:stopPropagation="true"
                                @onclick="() => RemoveSchemaTab(index)"
                                title="Remove">×</button>
                    }
                </div>
            }
            <button class="schema-tab-add" @onclick="AddSchemaTab" title="Add schema file">+</button>
        </div>
        <div class="panel-content">
            <StandaloneCodeEditor @ref="schemaEditor"
                Id="schema-editor"
                ConstructionOptions="SchemaEditorOptions"
                OnDidInit="OnSchemaEditorInit" />
        </div>
    </div>

    @* Top-right: Type map *@
    <div class="playground-panel @(GetPanelClass("typemap"))">
        <div class="panel-header">
            Type Map
            @if (generationResult?.TypeMap.Count > 0)
            {
                <span class="badge">@generationResult.TypeMap.Count types</span>
            }
        </div>
        <div class="panel-content">
            <TypeMapPanel TypeMap="@(generationResult?.TypeMap ?? [])"
                          OnSchemaPointerSelected="OnSchemaPointerSelected" />
        </div>
    </div>

    @* Bottom-left: User code editor *@
    <div class="playground-panel @(GetPanelClass("usercode"))">
        <div class="panel-header">
            User Code (C#)
            <div class="spacer"></div>
            <button class="panel-copy-btn" @onclick="CopyUserCode" title="Copy code">📋</button>
            <button class="panel-maximize-btn" @onclick='() => ToggleMaximize("usercode")' title="@(maximizedPanel == "usercode" ? "Restore" : "Maximize")">
                @(maximizedPanel == "usercode" ? "⊟" : "⊞")
            </button>
        </div>
        <div class="panel-content">
            <StandaloneCodeEditor @ref="userCodeEditor"
                Id="user-code-editor"
                ConstructionOptions="UserCodeEditorOptions"
                OnDidInit="OnUserCodeEditorInit" />
        </div>
    </div>

    @* Bottom-right: Console output *@
    <div class="playground-panel @(GetPanelClass("console"))">
        <div class="panel-header">
            Console Output
            <div class="spacer"></div>
            <button class="panel-copy-btn" @onclick="CopyConsoleOutput" title="Copy output">📋</button>
            <button class="panel-maximize-btn" @onclick='() => ToggleMaximize("console")' title="@(maximizedPanel == "console" ? "Restore" : "Maximize")">
                @(maximizedPanel == "console" ? "⊟" : "⊞")
            </button>
        </div>
        <div class="panel-content">
            <div class="console-output" @ref="consoleDiv">
                @foreach (var line in consoleLines)
                {
                    <span class="@line.CssClass">@line.Text</span>
                }
            </div>
        </div>
    </div>
</div>

<div class="status-bar @(statusError ? "error" : "")">
    <span class="status-item">@statusText</span>
</div>

@code {
    private StandaloneCodeEditor? schemaEditor;
    private StandaloneCodeEditor? userCodeEditor;
    private ElementReference consoleDiv;
    private GenerationResult? generationResult;
    private bool isGenerating;
    private bool isRunning;
    private string statusText = "Ready";
    private bool statusError;
    private List<ConsoleLine> consoleLines = [];
    private string? maximizedPanel;

    // Sample registry state
    private IReadOnlyList<PlaygroundSample> availableSamples = [];
    private string? activeSampleId;

    // Multi-schema state
    private List<SchemaFile> schemaFiles = [];
    private int activeSchemaIndex;
    private int renamingTabIndex = -1;
    private string renameValue = "";
    private ElementReference renameInputRef;
    private bool focusRenameInput;

    private const string EmptySchemaContent = "{\n  \"$schema\": \"https://json-schema.org/draft/2020-12/schema\"\n}";
    private const string NewProjectUserCode = "using Corvus.Text.Json;\nusing Playground;\n";
    private const string NewProjectId = "new";

    private StandaloneEditorConstructionOptions SchemaEditorOptions(StandaloneCodeEditor editor)
    {
        string initialContent = schemaFiles.Count > 0
            ? schemaFiles[activeSchemaIndex].Content
            : "{\n  \"type\": \"object\"\n}";

        return new StandaloneEditorConstructionOptions
        {
            AutomaticLayout = true,
            Language = "json",
            Theme = "vs-dark",
            Value = initialContent,
            FontSize = 13,
            Minimap = new EditorMinimapOptions { Enabled = false },
            ScrollBeyondLastLine = false,
        };
    }

    private StandaloneEditorConstructionOptions UserCodeEditorOptions(StandaloneCodeEditor editor)
    {
        return new StandaloneEditorConstructionOptions
        {
            AutomaticLayout = true,
            Language = "csharp",
            Theme = "vs-dark",
            Value = GetInitialUserCode(),
            FontSize = 13,
            Minimap = new EditorMinimapOptions { Enabled = false },
            ScrollBeyondLastLine = false,
        };
    }

    protected override void OnInitialized()
    {
        // Load all recipe samples
        availableSamples = SampleRegistry.LoadAll();

        // Default to a blank "New Project"
        LoadNewProject();
    }

    private string GetInitialUserCode()
    {
        if (activeSampleId is not null && activeSampleId != NewProjectId)
        {
            PlaygroundSample? sample = availableSamples.FirstOrDefault(s => s.Id == activeSampleId);
            if (sample is not null)
            {
                return sample.UserCode;
            }
        }

        return NewProjectUserCode;
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (focusRenameInput)
        {
            focusRenameInput = false;
            try
            {
                await renameInputRef.FocusAsync();
            }
            catch
            {
                // Element may not yet be in DOM; ignore
            }
        }
    }

    private async Task OnSchemaEditorInit()
    {
        // Editor is ready
    }

    private DotNetObjectReference<MainLayout>? intelliSenseRef;

    private async Task OnUserCodeEditorInit()
    {
        await RegisterCompletionProvider();
    }

    private async Task RegisterCompletionProvider()
    {
        this.intelliSenseRef = DotNetObjectReference.Create(this);
        await JSRuntime.InvokeVoidAsync("registerCSharpCompletionProvider", this.intelliSenseRef);
    }

    [JSInvokable]
    public async Task<List<object>> GetCompletionsForJs(string code, int line, int column)
    {
        var items = await IntelliSenseSvc.GetCompletionsAsync(code, line, column);

        return items.Select(item => (object)new
        {
            label = item.Label,
            kind = MapMonacoKind(item.Kind),
            detail = item.Detail,
            insertText = item.Label,
            sortText = item.SortText,
            filterText = item.FilterText,
        }).ToList();
    }

    private static int MapMonacoKind(string kind)
    {
        // Monaco CompletionItemKind integer values
        return kind switch
        {
            "Method" => 0,
            "Function" => 1,
            "Field" => 3,
            "Variable" => 4,
            "Class" => 5,
            "Struct" => 6,
            "Interface" => 7,
            "Module" => 8,
            "Property" => 9,
            "Event" => 10,
            "Constant" => 14,
            "Enum" => 15,
            "EnumMember" => 16,
            "Keyword" => 17,
            "Snippet" => 27,
            "TypeParameter" => 24,
            _ => 18, // Text
        };
    }

    private async Task CopyUserCode()
    {
        if (userCodeEditor is not null)
        {
            string code = await userCodeEditor.GetValue();
            await JSRuntime.InvokeVoidAsync("navigator.clipboard.writeText", code);
        }
    }

    private async Task CopyConsoleOutput()
    {
        string text = string.Join("\n", consoleLines.Select(l => l.Text));
        await JSRuntime.InvokeVoidAsync("navigator.clipboard.writeText", text);
    }

    private async Task OnSampleChanged(ChangeEventArgs e)
    {
        string? sampleId = e.Value?.ToString();
        if (string.IsNullOrEmpty(sampleId))
        {
            return;
        }

        if (sampleId == NewProjectId)
        {
            LoadNewProject();

            if (schemaEditor is not null)
            {
                await schemaEditor.SetValue(schemaFiles[0].Content);
            }

            if (userCodeEditor is not null)
            {
                await userCodeEditor.SetValue(NewProjectUserCode);
            }

            generationResult = null;
            await ClearEditorMarkers();
            await ClearSchemaEditorMarkers();
            statusText = "Ready";
            statusError = false;
            return;
        }

        PlaygroundSample? sample = availableSamples.FirstOrDefault(s => s.Id == sampleId);
        if (sample is null || schemaEditor is null)
        {
            return;
        }

        LoadSample(sample);

        // Update editors
        activeSchemaIndex = 0;
        await schemaEditor.SetValue(schemaFiles[0].Content);

        if (userCodeEditor is not null)
        {
            await userCodeEditor.SetValue(sample.UserCode);
        }

        // Reset generation state
        generationResult = null;
        await ClearEditorMarkers();
        await ClearSchemaEditorMarkers();
        statusText = "Ready — sample loaded";
        statusError = false;
    }

    private void LoadNewProject()
    {
        activeSampleId = NewProjectId;
        schemaFiles.Clear();
        schemaFiles.Add(new SchemaFile
        {
            Name = "schema.json",
            Content = EmptySchemaContent,
            IsRootType = true,
        });
        activeSchemaIndex = 0;
    }

    private void LoadSample(PlaygroundSample sample)
    {
        activeSampleId = sample.Id;

        schemaFiles.Clear();
        foreach (SampleSchemaFile schema in sample.Schemas)
        {
            schemaFiles.Add(new SchemaFile
            {
                Name = schema.Name,
                Content = schema.Content,
                IsRootType = schema.IsRootType,
                TypeName = schema.TypeName,
            });
        }

        activeSchemaIndex = 0;
    }

    private async Task SelectSchemaTab(int index)
    {
        if (index == activeSchemaIndex || schemaEditor is null)
        {
            return;
        }

        // Save current tab content
        schemaFiles[activeSchemaIndex].Content = await schemaEditor.GetValue();

        // Switch to new tab
        activeSchemaIndex = index;
        await schemaEditor.SetValue(schemaFiles[activeSchemaIndex].Content);
    }

    private void ToggleRootType(int index)
    {
        schemaFiles[index].IsRootType = !schemaFiles[index].IsRootType;
    }

    private void StartRename(int index)
    {
        renamingTabIndex = index;
        // Strip .json for editing, user edits only the stem
        string name = schemaFiles[index].Name;
        renameValue = name.EndsWith(".json", StringComparison.OrdinalIgnoreCase)
            ? name[..^5]
            : name;
        focusRenameInput = true;
    }

    private void OnRenameKeyDown(KeyboardEventArgs e)
    {
        if (e.Key == "Enter")
        {
            CommitRename();
        }
        else if (e.Key == "Escape")
        {
            renamingTabIndex = -1;
        }
    }

    private void CommitRename()
    {
        if (renamingTabIndex < 0 || renamingTabIndex >= schemaFiles.Count)
        {
            renamingTabIndex = -1;
            return;
        }

        string stem = renameValue.Trim();

        // Validate: must not be empty, must not contain invalid chars
        if (string.IsNullOrWhiteSpace(stem) ||
            stem.IndexOfAny(['.', '/', '\\', ' ']) >= 0)
        {
            // Revert — keep existing name
            renamingTabIndex = -1;
            return;
        }

        string newName = stem + ".json";

        // Check for duplicates (case-insensitive, excluding current tab)
        bool isDuplicate = schemaFiles
            .Where((f, i) => i != renamingTabIndex)
            .Any(f => string.Equals(f.Name, newName, StringComparison.OrdinalIgnoreCase));

        if (!isDuplicate)
        {
            schemaFiles[renamingTabIndex].Name = newName;
        }

        renamingTabIndex = -1;
    }

    private async Task AddSchemaTab()
    {
        // Save current tab content before switching
        if (schemaEditor is not null)
        {
            schemaFiles[activeSchemaIndex].Content = await schemaEditor.GetValue();
        }

        int number = schemaFiles.Count + 1;
        schemaFiles.Add(new SchemaFile
        {
            Name = $"schema{number}.json",
            Content = EmptySchemaContent,
            IsRootType = false,
        });

        activeSchemaIndex = schemaFiles.Count - 1;

        if (schemaEditor is not null)
        {
            await schemaEditor.SetValue(schemaFiles[activeSchemaIndex].Content);
        }
    }

    private async Task RemoveSchemaTab(int index)
    {
        if (schemaFiles.Count <= 1)
        {
            return;
        }

        schemaFiles.RemoveAt(index);

        if (activeSchemaIndex >= schemaFiles.Count)
        {
            activeSchemaIndex = schemaFiles.Count - 1;
        }
        else if (index < activeSchemaIndex)
        {
            activeSchemaIndex--;
        }

        if (schemaEditor is not null)
        {
            await schemaEditor.SetValue(schemaFiles[activeSchemaIndex].Content);
        }
    }

    private async Task GenerateAsync()
    {
        if (schemaEditor is null)
        {
            return;
        }

        isGenerating = true;
        statusText = "Generating types…";
        statusError = false;
        StateHasChanged();

        try
        {
            // Save current editor content to active tab
            schemaFiles[activeSchemaIndex].Content = await schemaEditor.GetValue();

            // Generate from all schema files
            generationResult = await CodeGenService.GenerateAsync(schemaFiles);

            if (generationResult.Success)
            {
                statusText = $"Generated {generationResult.TypeMap.Count} types, {generationResult.GeneratedFiles.Count} files";
                await ClearSchemaEditorMarkers();

                // Update IntelliSense with the generated code
                IntelliSenseSvc.UpdateGeneratedCode(generationResult.GeneratedFiles);
            }
            else
            {
                statusText = generationResult.ErrorMessage ?? "Generation failed";
                statusError = true;

                if (generationResult.SchemaErrors.Count > 0)
                {
                    await SetSchemaEditorMarkers(generationResult.SchemaErrors);
                }
                else
                {
                    WriteConsole(generationResult.ErrorMessage ?? "Generation failed", "error");
                }
            }
        }
        catch (Exception ex)
        {
            statusText = $"Error: {ex.Message}";
            statusError = true;
            WriteConsole($"Error: {ex.Message}", "error");
        }
        finally
        {
            isGenerating = false;
            StateHasChanged();
        }
    }

    private CancellationTokenSource? runCts;

    private async Task RunAsync()
    {
        if (generationResult is null || !generationResult.Success || userCodeEditor is null)
        {
            return;
        }

        isRunning = true;
        consoleLines.Clear();
        statusText = "Loading assemblies…";
        statusError = false;
        StateHasChanged();

        try
        {
            runCts?.Cancel();
            runCts = new CancellationTokenSource();

            // Clear previous error markers
            await ClearEditorMarkers();

            string userCode = await userCodeEditor.GetValue();

            // Step 1: Compile generated code + user code
            statusText = "Building…";
            StateHasChanged();

            // Allow UI to update before blocking compilation
            await Task.Delay(50);

            CompilationResult compilationResult = await CompilationSvc.CompileAsync(
                generationResult.GeneratedFiles,
                userCode);

            if (!compilationResult.Success)
            {
                statusText = $"Build failed — {compilationResult.Diagnostics.Count} error(s)";
                statusError = true;

                await SetEditorMarkers(compilationResult.Diagnostics);

                foreach (var diagnostic in compilationResult.Diagnostics)
                {
                    string location = diagnostic.Location.IsInSource
                        ? $" (line {diagnostic.Location.GetLineSpan().StartLinePosition.Line + 1})"
                        : string.Empty;
                    WriteConsole($"{diagnostic.Severity}: {diagnostic.GetMessage()}{location}", "error");
                }

                return;
            }

            if (compilationResult.Assembly is null)
            {
                statusText = "Build produced no output";
                statusError = true;
                return;
            }

            // Step 2: Execute the compiled assembly
            statusText = "Running…";
            StateHasChanged();

            ExecutionResult executionResult = await ExecutionSvc.ExecuteAsync(
                compilationResult.Assembly,
                runCts.Token);

            if (!string.IsNullOrEmpty(executionResult.Output))
            {
                foreach (string line in executionResult.Output.Split('\n'))
                {
                    if (!string.IsNullOrEmpty(line))
                    {
                        WriteConsole(line.TrimEnd('\r'));
                    }
                }
            }

            if (executionResult.Success)
            {
                statusText = "Execution complete";
            }
            else
            {
                statusText = "Execution failed";
                statusError = true;
                if (executionResult.ErrorMessage is not null)
                {
                    WriteConsole(executionResult.ErrorMessage, "error");
                }
            }
        }
        catch (Exception ex)
        {
            statusText = $"Error: {ex.Message}";
            statusError = true;
            WriteConsole($"Error: {ex.Message}", "error");
        }
        finally
        {
            isRunning = false;
            StateHasChanged();
        }
    }

    private async Task SetEditorMarkers(List<Microsoft.CodeAnalysis.Diagnostic> diagnostics)
    {
        if (userCodeEditor is null)
        {
            return;
        }

        var model = await userCodeEditor.GetModel();
        if (model is null)
        {
            return;
        }

        var markers = new List<MarkerData>();
        foreach (var diagnostic in diagnostics)
        {
            // Only show markers for user code (Program.cs), not generated files
            if (!diagnostic.Location.IsInSource)
            {
                continue;
            }

            var lineSpan = diagnostic.Location.GetLineSpan();
            if (lineSpan.Path != "Program.cs")
            {
                continue;
            }

            var start = lineSpan.StartLinePosition;
            var end = lineSpan.EndLinePosition;

            markers.Add(new MarkerData
            {
                Message = diagnostic.GetMessage(),
                Severity = diagnostic.Severity == Microsoft.CodeAnalysis.DiagnosticSeverity.Error
                    ? MarkerSeverity.Error
                    : MarkerSeverity.Warning,
                StartLineNumber = start.Line + 1,
                StartColumn = start.Character + 1,
                EndLineNumber = end.Line + 1,
                EndColumn = end.Character + 1,
            });
        }

        await BlazorMonaco.Editor.Global.SetModelMarkers(JSRuntime, model, "playground", markers);
    }

    private async Task ClearEditorMarkers()
    {
        if (userCodeEditor is null)
        {
            return;
        }

        var model = await userCodeEditor.GetModel();
        if (model is not null)
        {
            await BlazorMonaco.Editor.Global.SetModelMarkers(JSRuntime, model, "playground", []);
        }
    }

    private async Task SetSchemaEditorMarkers(IReadOnlyList<SchemaError> errors)
    {
        if (schemaEditor is null || errors.Count == 0)
        {
            return;
        }

        // Switch to the first schema tab that has an error
        var firstError = errors[0];
        int errorTabIndex = schemaFiles.FindIndex(f =>
            string.Equals(f.Name, firstError.SchemaName, StringComparison.OrdinalIgnoreCase));
        if (errorTabIndex >= 0 && errorTabIndex != activeSchemaIndex)
        {
            await SelectSchemaTab(errorTabIndex);
            StateHasChanged();
        }

        // Build markers for errors in the currently visible schema
        string currentSchemaName = schemaFiles[activeSchemaIndex].Name;
        var markers = new List<MarkerData>();
        foreach (var error in errors.Where(e =>
            string.Equals(e.SchemaName, currentSchemaName, StringComparison.OrdinalIgnoreCase)))
        {
            int line = (int)(error.LineNumber ?? 0) + 1;
            int col = (int)(error.Column ?? 0) + 1;

            markers.Add(new MarkerData
            {
                Message = error.Message,
                Severity = MarkerSeverity.Error,
                StartLineNumber = line,
                StartColumn = col,
                EndLineNumber = line,
                EndColumn = col + 1,
            });

            WriteConsole($"{error.SchemaName}({line},{col}): {error.Message}", "error");
        }

        // Also show errors for other schema files in the console
        foreach (var error in errors.Where(e =>
            !string.Equals(e.SchemaName, currentSchemaName, StringComparison.OrdinalIgnoreCase)))
        {
            int line = (int)(error.LineNumber ?? 0) + 1;
            int col = (int)(error.Column ?? 0) + 1;
            WriteConsole($"{error.SchemaName}({line},{col}): {error.Message}", "error");
        }

        var model = await schemaEditor.GetModel();
        if (model is not null)
        {
            await BlazorMonaco.Editor.Global.SetModelMarkers(JSRuntime, model, "schema-errors", markers);
        }

        // Navigate to the first error location
        if (firstError.LineNumber.HasValue)
        {
            int navLine = (int)firstError.LineNumber.Value + 1;
            await schemaEditor.RevealLineInCenter(navLine);
            await schemaEditor.SetPosition(new Position { LineNumber = navLine, Column = 1 }, "");
        }
    }

    private async Task ClearSchemaEditorMarkers()
    {
        if (schemaEditor is null)
        {
            return;
        }

        var model = await schemaEditor.GetModel();
        if (model is not null)
        {
            await BlazorMonaco.Editor.Global.SetModelMarkers(JSRuntime, model, "schema-errors", []);
        }
    }

    private async Task OnSchemaPointerSelected(TypeMapPanel.SchemaNavigation nav)
    {
        if (schemaEditor is null || nav.Pointer is null)
        {
            return;
        }

        // Switch to the correct schema tab if the type comes from a different file
        if (nav.SchemaName is not null)
        {
            int tabIndex = schemaFiles.FindIndex(f =>
                string.Equals(f.Name, nav.SchemaName, StringComparison.OrdinalIgnoreCase));
            if (tabIndex >= 0 && tabIndex != activeSchemaIndex)
            {
                await SelectSchemaTab(tabIndex);
                StateHasChanged();
            }
        }

        // Find the line in the schema editor that corresponds to this JSON pointer
        string schemaText = await schemaEditor.GetValue();
        int line = FindLineForJsonPointer(schemaText, nav.Pointer);
        if (line > 0)
        {
            await schemaEditor.RevealLineInCenter(line);
            await schemaEditor.SetPosition(new Position { LineNumber = line, Column = 1 }, "");
        }
    }

    /// <summary>
    /// Finds the 1-based line number in a JSON string that corresponds to a JSON pointer.
    /// E.g. "#/properties/address" finds the line containing "address" under "properties".
    /// </summary>
    private static int FindLineForJsonPointer(string json, string pointer)
    {
        // Strip leading "#" or "#/"
        string path = pointer.TrimStart('#').TrimStart('/');
        if (string.IsNullOrEmpty(path))
        {
            return 1;
        }

        string[] segments = path.Split('/');
        string[] lines = json.Split('\n');

        // Walk through segments, finding each key in order
        int currentLine = 0;
        foreach (string segment in segments)
        {
            // Unescape JSON Pointer encoding
            string key = segment.Replace("~1", "/").Replace("~0", "~");
            string searchPattern = $"\"{key}\"";

            bool found = false;
            for (int i = currentLine; i < lines.Length; i++)
            {
                if (lines[i].Contains(searchPattern))
                {
                    currentLine = i;
                    found = true;
                    break;
                }
            }

            if (!found)
            {
                return currentLine + 1; // Return best match so far (1-based)
            }
        }

        return currentLine + 1; // Convert to 1-based
    }

    private void WriteConsole(string text, string cssClass = "")
    {
        consoleLines.Add(new ConsoleLine(text + "\n", cssClass));
    }

    private void ToggleMaximize(string panelName)
    {
        maximizedPanel = maximizedPanel == panelName ? null : panelName;
    }

    private string GetPanelClass(string panelName)
    {
        if (maximizedPanel is null)
        {
            return "";
        }

        return maximizedPanel == panelName ? "maximized" : "hidden";
    }

    private record ConsoleLine(string Text, string CssClass);
}
